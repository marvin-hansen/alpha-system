load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "assets_tests",
    srcs = glob([
        "assets_tests.rs",
    ]),
    tags = [
        "common",
        "common_meta_data",
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:common_metadata",
        # External crates
        "@crates//:chrono",
        "@crates//:serde",
        "@crates//:serde_json",
    ],
)

