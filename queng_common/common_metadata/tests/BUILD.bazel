load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "assets",
    srcs = glob([
        "assets_tests.rs",
    ]),
    tags = [
        "common",
        "common_meta_data",
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:common_metadata",
        # External crates
        "//thirdparty/crates:chrono",
        "//thirdparty/crates:serde",
        "//thirdparty/crates:serde_json",
    ],
)

