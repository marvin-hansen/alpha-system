load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test")


rust_library(
    name = "lib_data_stream",
    crate_root = "src/lib/mod.rs",
    srcs = glob([
        "src/lib/*.rs",
    ]),
    deps =  [
        # Internal crates
        "//:common",
        "//:config_manager",
        "//:ctx_manager",
        "//:dns_manager",
        "//:rust_proto",
        "//:service_utils",
        "//:smdb_provider",
        # External crates
        "@crates//:tokio",
        "@crates//:tonic",
        "@crates//:prost",
    ],
    visibility = ["//visibility:public"],
)

rust_doc(
    name = "doc",
    crate = ":lib_data_stream",
    visibility = ["//visibility:public"],
)

rust_doc_test(
     name = "doc_test",
     crate = ":lib_data_stream",
     visibility = ["//visibility:public"],
)
