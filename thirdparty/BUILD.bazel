load("@rules_rust//crate_universe:defs.bzl", "crate", "crates_vendor")

crates_vendor(
    name = "crates_vendor",
    annotations = {
        "protoc-gen-prost": [
            crate.annotation(
                gen_binaries = ["protoc-gen-prost"],
            ),
        ],
        "protoc-gen-tonic": [
            crate.annotation(
                gen_binaries = ["protoc-gen-tonic"],
            ),
        ],
        "pq-sys": [
            crate.annotation(
                build_script_env = {
                    "PQ_LIB_STATIC": "1",
                },
                compile_data = ["@@libpq+//:libpq"],
                rustc_flags = [
                    "-L",
                    "$(BINDIR)/external/libpq+",
                ],
            ),
        ],
    },
    mode = "local",
    packages = {
        #
        # Dependencies for integration tests
        "docker_utils": crate.spec(
            package = "docker_utils",
            version = "0.2",
        ),
        "service_utils": crate.spec(
            package = "service_utils",
            version = "0.2",
        ),
        #
        # Proc macros dependencies
        "async-trait": crate.spec(
            package = "async-trait",
            version = "0.1",
        ),
        "enum_dispatch": crate.spec(
            package = "enum_dispatch",
            version = "0.3",
        ),
        "trait-variant": crate.spec(
            default_features = False,
            package = "trait-variant",
            version = "0.1",
        ),
        "syn": crate.spec(
            default_features = True,
            features = [
                "full",
                "extra-traits",
            ],
            package = "syn",
            version = "2.0",
        ),
        "quote": crate.spec(
            default_features = True,
            package = "quote",
            version = "1.0",
        ),
        #
        # Regular dependencies
        "ahash": crate.spec(
            default_features = False,
            features = ["serde"],
            package = "ahash",
            version = "0.8",
        ),
        "base16ct": crate.spec(
            default_features = False,
            features = ["alloc"],
            package = "base16ct",
            version = "0.2",
        ),
        "blake3": crate.spec(
            default_features = True,
            package = "blake3",
            version = "1.5",
        ),
        "bytes": crate.spec(
            default_features = True,
            package = "bytes",
            version = "1.8",
        ),
        "chrono": crate.spec(
            features = ["serde"],
            package = "chrono",
            version = "0.4",
        ),
        "crossbeam": crate.spec(
            package = "crossbeam",
            version = "0.8",
        ),
        "diesel": crate.spec(
            default_features = False,
            features = [
                "postgres",
                "r2d2",
            ],
            package = "diesel",
            version = "2.2",
        ),
        "diesel_migrations": crate.spec(
            default_features = False,
            features = ["postgres"],
            package = "diesel_migrations",
            version = "2.2",
        ),
        "futures": crate.spec(
            package = "futures",
            version = "0.3",
        ),
        "futures-util": crate.spec(
            package = "futures-util",
            version = "0.3",
        ),
        "pq-sys": crate.spec(
            package = "pq-sys",
            # pegged to 0.6.3 because 0.7 doesn't compile.
            version = "0.6.3",
        ),
        "hickory-resolver": crate.spec(
            default_features = False,
            features = ["tokio-runtime"],
            package = "hickory-resolver",
            version = "0.24",
        ),
        "iggy": crate.spec(
            package = "iggy",
            version = "0.6.200",
        ),
        "klickhouse": crate.spec(
            package = "klickhouse",
            version = "0.13",
        ),
        "lru": crate.spec(
            package = "lru",
            version = "0.12",
        ),
        "mimalloc": crate.spec(
            package = "mimalloc",
            version = "0.1",
        ),
        "prost": crate.spec(
            package = "prost",
            version = "0.13",
        ),
        "prost-types": crate.spec(
            default_features = False,
            package = "prost-types",
            version = "0.13",
        ),
        "protoc-gen-prost": crate.spec(
            package = "protoc-gen-prost",
            version = "0.4",
        ),
        "protoc-gen-tonic": crate.spec(
            package = "protoc-gen-tonic",
            version = "0.4",
        ),
        "reqwest": crate.spec(
            default_features = False,
            features = [
                "rustls-tls",
                "json",
                "blocking",
                "gzip",
            ],
            package = "reqwest",
            version = "0.12",
        ),
        "rust_decimal": crate.spec(
            package = "rust_decimal",
            version = "1.36",
        ),
        "rust_decimal_macros": crate.spec(
            package = "rust_decimal_macros",
            version = "1.36",
        ),
        "rustls": crate.spec(
            features = ["ring"],
            package = "rustls",
            version = "0.23.23",
        ),
        "serde": crate.spec(
            features = ["derive"],
            package = "serde",
            version = "1.0",
        ),
        "serde_json": crate.spec(
            package = "serde_json",
            version = "1.0",
        ),
        "sha3": crate.spec(
            default_features = False,
            package = "sha3",
            version = "0.11.0-pre.4",
        ),
        "tokio": crate.spec(
            default_features = False,
            features = [
                "macros",
                "net",
                "rt-multi-thread",
                "signal",
                "time",
            ],
            package = "tokio",
            version = "1.42",
        ),
        "tokio-tungstenite": crate.spec(
            features = ["rustls-tls-webpki-roots"],
            package = "tokio-tungstenite",
            version = "0.26",
        ),
        "tonic": crate.spec(
            features = ["transport"],
            package = "tonic",
            version = "0.12",
        ),
        "tonic-build": crate.spec(
            package = "tonic-build",
            version = "0.12",
        ),
        "tonic-health": crate.spec(
            default_features = False,
            features = ["transport"],
            package = "tonic-health",
            version = "0.12",
        ),
        "warp": crate.spec(
            package = "warp",
            version = "0.3",
        ),
    },
    repository_name = "queng_vendored",
    tags = ["manual"],
)
