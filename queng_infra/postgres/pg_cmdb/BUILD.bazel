load("@bazel_skylib//rules:copy_directory.bzl", "copy_directory")
load("@bazel_skylib//rules:copy_file.bzl", "copy_file")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library")

genrule(
    name = "gen_env_file",
    srcs = ["Cargo.toml"],
    outs = ["env_file.txt"],
    cmd = """(
        # Get the absolute path
        input_path=$$(pwd -P)

        # Remove /Cargo.toml from the path
        result_path="$${input_path%/Cargo.toml}"

        # Output the modified path
        echo "CARGO_MANIFEST_DIR=$$result_path"
     ) | tee $@""",
    executable = True,
)

filegroup(
    name = "diesel_toml",
    srcs = ["diesel.toml"],
)

copy_directory(
    name = "copy_migrations",
    src = "migrations",
    out = "migrations",
)

rust_library(
    name = "pg_cmdb",
    srcs = glob([
        "src/**",
    ]),
    compile_data = [
        ":diesel_toml",
        ":copy_migrations",
    ],
    crate_root = "src/lib.rs",
    rustc_env_files = [
        ":gen_env_file",
    ],
    tags = [
        "infra",
        "pg_cmdb",
        "postgres",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_exchange",
        # External crates
        "@crates//:diesel",
        "@crates//:diesel_migrations",
        "@crates//:serde",
    ],
)

rust_doc(
    name = "doc",
    crate = ":pg_cmdb",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":pg_cmdb",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
