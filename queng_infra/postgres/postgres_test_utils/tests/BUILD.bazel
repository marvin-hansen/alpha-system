load("@rules_rust//rust:defs.bzl", "rust_test")

##
## Setup
##  - Run once before all tests
rust_test(
    name = "postgres_setup",
    srcs = glob([
        "test_full_setup.rs",
    ]),
    exec_properties = {
        # Tell BuildBuddy to run this test using a Firecracker microVM.
        "test.workload-isolation-type": "firecracker",
        # Tell BuildBuddy to ensure that the Docker daemon is started
        "test.init-dockerd": "true",
        # Tell BuildBuddy to preserve the microVM state across test runs.
        "test.recycle-runner": "true",
        # We don't want different different db tests to be assigned to the same recycled runner,
        # because we can't fit all db docker images with the default disk limit.
        "test.runner-recycling-key": "db_postgres_utils_tests",
    },
    tags = [
        "test-setup",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:postgres_test_utils",
        # External crates
        "@crates//:tokio",
    ],
)

##
## Teardown
##  - Run once after all tests if you want to reset the database
rust_test(
    name = "postgres_teardown",
    srcs = glob([
        "test_full_teardown.rs",
    ]),
    exec_properties = {
        # Tell BuildBuddy to run this test using a Firecracker microVM.
        "test.workload-isolation-type": "firecracker",
        # Tell BuildBuddy to ensure that the Docker daemon is started
        "test.init-dockerd": "true",
        # Tell BuildBuddy to preserve the microVM state across test runs.
        "test.recycle-runner": "true",
        # We don't want different different db tests to be assigned to the same recycled runner,
        # because we can't fit all db docker images with the default disk limit.
        "test.runner-recycling-key": "db_postgres_utils_tests",
    },
    tags = [
        "test-teardown",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:postgres_test_utils",
        # External crates
        "@crates//:tokio",
    ],
)