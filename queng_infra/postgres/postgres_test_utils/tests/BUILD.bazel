        "test.runner-recycling-key": "db_postgres_diesel_tests",
    },
    tags = [
        "test-teardown",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:postgres_test_utils",
        # Internal crates

        # External crates
        "@crates//:tokio",
    ],
)
