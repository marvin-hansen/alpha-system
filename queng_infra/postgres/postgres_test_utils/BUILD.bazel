load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library")

rust_library(
    name = "postgres_test_utils",
    srcs = glob([
        "src/*.rs",
    ]),
    crate_root = "src/lib.rs",
    tags = [
        "database_utils",
        "utils-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_database",
        "//alias:common_exchange",
        "//alias:container_specs",
        "//alias:docker_utils",
        # Internal database crates
        "//alias:pg_cmdb",
        "//alias:pg_smdb",
        "//alias:pg_mddb",
        # External crates
        "@crates//:diesel",
        "@crates//:tokio",
    ],
)

rust_doc(
    name = "doc",
    crate = ":postgres_test_utils",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":postgres_test_utils",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
