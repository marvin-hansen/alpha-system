load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "tests",
    srcs = glob([
        "type_conversion/*_tests.rs",
    ]),
    tags = [
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:pg_mddb",
        # Internal crates
        "//alias:common_metadata",
        "//alias:postgres_migrations",
        # External crates
        "//thirdparty/crates:bon",
        "//thirdparty/crates:diesel",
        "//thirdparty/crates:diesel_migrations",
    ],
)

rust_test_suite(
    name = "asset_tests",
    srcs = glob([
        "asset/asset_tests.rs",
    ]),
    exec_properties = {
        # Tell BuildBuddy to run this test using a Firecracker microVM.
        "test.workload-isolation-type": "firecracker",
        # Tell BuildBuddy to ensure that the Docker daemon is started
        "test.init-dockerd": "true",
        # Tell BuildBuddy to preserve the microVM state across test runs.
        "test.recycle-runner": "true",
        # We don't want different different db tests to be assigned to the same recycled runner,
        # because we can't fit all db docker images with the default disk limit.
        "test.runner-recycling-key": "mddb_asset_tests",
    },
    tags = [
        # "integration_test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:pg_mddb",
        # Internal crates
        "//alias:common_metadata",
        "//alias:postgres_migrations",
        "//alias:postgres_test_utils",
        "//alias:env_utils",
        # External crates
        "//thirdparty/crates:diesel",
        "//thirdparty/crates:diesel_migrations",
        "//thirdparty/crates:tokio",
    ],
)
