###############################################################################
# Imports
###############################################################################

# OCI Container Rules
load("@rules_oci//oci:defs.bzl", "oci_push")

# Rules rust
load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_doc", "rust_doc_test")

# Custom optimized Rust binary macro
load("//:build/binary.bzl", "build_binary_opt")

# Custom container macro
load("//:build/container.bzl", "build_multi_arch_image", "build_sha265_tag")

###############################################################################
# Rust Binary
###############################################################################

# Build optimized binary
build_binary_opt(
    name = "cmdb",
    srcs = glob([
        "src/**/*.rs",
    ]),
    deps = [
        # Specs
        "//alias:cmdb_specs",
        # Service template
        "//alias/service:grpc_service",
        # Internal crates
        "//alias:common_config",
        "//alias:config_manager",
        "//alias:pg_cmdb_manager",
        "//alias:proto_cmdb",
        "//alias:proto_cmdb_utils",
        "//alias:common_service",
        "//alias/client:smdb_client",
        # Custom Memory Allocator
        "//thirdparty/crates:mimalloc",
        # External crates
        "//thirdparty/crates:tokio",
        "//thirdparty/crates:tonic",
    ],
)

###############################################################################
# Documentation
###############################################################################

# Build documentation
rust_doc(
    name = "doc",
    crate = ":cmdb",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

# Test documentation
rust_doc_test(
    name = "doc_test",
    crate = ":cmdb",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)

###############################################################################
# OCI Container Image
###############################################################################

# Build container image
build_multi_arch_image(
    name = "image_index",
    srcs = ["cmdb"],
    base = "@distroless",
    exposed_ports = [
        "7070",
        "8080",
    ],
    platforms = [
        "//build/platforms:linux_x86_64_musl",
        "//build/platforms:linux_arm64_musl",
    ],
    visibility = ["//visibility:public"],
)

# Build an unique and immutable image tag based on the image SHA265 digest.
build_sha265_tag(
    name = "remote_tag",
    image = ":image_index",
    input = "image.json.sha256",
    output = "_tag.txt",
)

# Publish image to registry
oci_push(
    name = "push",
    image = ":image_index",
    remote_tags = ":remote_tag",
    repository = "asia-northeast1-docker.pkg.dev/future-309012/image-repo/cmdb",
    visibility = ["//visibility:public"],
)
