load("@aspect_bazel_lib//lib:copy_file.bzl", "copy_file")
load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "tests",
    srcs = glob([
        "*_tests.rs",
    ]),
    data = [
        ":copy_core_dbgw",
        ":copy_core_smdb",
        ":copy_ims_imdb",
    ],
    exec_properties = {
        # Tell BuildBuddy to run this test using a Firecracker microVM.
        "test.workload-isolation-type": "firecracker",
        # Tell BuildBuddy to ensure that the Docker daemon is started
        "test.init-dockerd": "true",
        # Tell BuildBuddy to preserve the microVM state across test runs.
        "test.recycle-runner": "true",
        # We want different different tests to be assigned to the same recycled runner,
        "test.runner-recycling-key": "imdb_test_runner",
    },
    tags = [
        # The first tag is for local testing, which must be in sequential order b/c there is just one DB
        "imdb_acceptance_test",
        # The second tag is for acceptance testing on the CI, which runs in parallel.
        "acceptance_test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate under test
        "//alias/client:imdb_client",
        # Internal crates
        "//alias:common_config",
        "//alias:common_ims",
        "//alias:config_manager",
        "//alias:container_specs_postgres",
        "//alias:integration_import",
        "//alias:service_import",
        # External crates
        "//thirdparty/crates:docker_utils",
        "//thirdparty/crates:service_utils",
        "//thirdparty/crates:tokio",
    ],
)

# Copy core services
copy_file(
    name = "copy_core_dbgw",
    src = "//alias/service:dbgw",
    out = "dbgw",
    is_executable = True,
)

copy_file(
    name = "copy_core_smdb",
    src = "//alias/service:smdb",
    out = "smdb",
    is_executable = True,
)

# Copy MDS files
copy_file(
    name = "copy_ims_imdb",
    src = "//alias/service:imdb",
    out = "imdb",
    is_executable = True,
)
