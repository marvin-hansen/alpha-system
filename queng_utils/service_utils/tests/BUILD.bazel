load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "tests",
    srcs = glob([
        "*_tests.rs",
    ]),
    # The Kaiko API Proxy used for testing doesn't need Docker,
    # hence no VM config needed for this integration test.
    tags = [
        "integration_test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate under test
        "//alias:service_utils",
        # Internal crates
        "//alias:common_config",
        "//alias:docker_utils",
        "//alias:container_specs_postgres",
        # External crates
        "//thirdparty/crates:tokio",
    ],
)
