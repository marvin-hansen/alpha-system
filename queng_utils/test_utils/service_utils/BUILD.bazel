load("@aspect_bazel_lib//lib:copy_file.bzl", "copy_file")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test")

copy_file(
    name = "copy_cmdb_bin",
    src = "//alias/service:cmdb",
    out = "cmdb",
    is_executable = True,
)

copy_file(
    name = "copy_dbgw_bin",
    src = "//alias/service:dbgw",
    out = "dbgw",
    is_executable = True,
)

copy_file(
    name = "copy_smdb_bin",
    src = "//alias/service:smdb",
    out = "smdb",
    is_executable = True,
)

rust_library(
    name = "service_utils",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    data = [
        ":copy_cmdb_bin",
        ":copy_dbgw_bin",
        ":copy_smdb_bin",
    ],
    tags = [
        "service_utils",
        "utils",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_config",
        "//alias:common_env",
        "//alias:ctx_manager",
    ],
)

rust_doc(
    name = "doc",
    crate = ":service_utils",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":service_utils",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
