load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test")

genrule(
    name = "copy_dbgw_bin",
    srcs = ["//alias/service:dbgw"],
    outs = ["dbgw"],
    cmd = "cp $(SRCS) $(OUTS)",
)

rust_library(
    name = "service_utils",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    data = [
        ":copy_dbgw_bin",
    ],
    tags = [
        "service_utils",
        "utils",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_config",
        "//alias:ctx_manager",
    ],
)

rust_doc(
    name = "doc",
    crate = ":service_utils",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":service_utils",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
