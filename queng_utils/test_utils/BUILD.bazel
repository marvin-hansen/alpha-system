load("@crate_index//:defs.bzl", "aliases", "all_crate_deps")
load("@rules_rust//rust:defs.bzl", "rust_library", "rust_binary", "rust_test")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test")


rust_binary(
    name = "test_bin",
    crate_root = "src/bin/main.rs",
    srcs = glob(["src/bin/*.rs"]),
    aliases = aliases(),
    proc_macro_deps = all_crate_deps(proc_macro = True),
    rustc_flags = select({
       "//:release": [
            "-Clto",
            "-Ccodegen-units=1",
            "-Cpanic=abort",
            "-Copt-level=3",
            "-Cstrip=symbols",
            ],
        "//conditions:default":
        [
           "-Copt-level=0",
        ],
    }),
    deps = all_crate_deps(
        normal = True,
    ) + [
        ":test_utils",
    ],
    visibility = ["//visibility:public"],
)

rust_library(
    name = "test_utils",
    crate_root = "src/lib.rs",
    srcs = glob([
        "src/**/*.rs",
    ]),
    aliases = aliases(),
    proc_macro_deps = all_crate_deps(proc_macro = True),
    deps = all_crate_deps(
        normal = True,
    ) + [
        "//queng_common:common",
    ],
    visibility = ["//visibility:public"],
)

rust_doc(
    name = "doc",
    crate = ":test_utils",
    visibility = ["//visibility:public"],
)

rust_doc_test(
     name = "doc_test",
     crate = ":test_utils",
     visibility = ["//visibility:public"],
)

rust_test(
    name = "test",
    srcs = glob([
        "tests/docker_utils/mod.rs",
    ]),
    deps = all_crate_deps(
        normal = True,
        normal_dev = True,
    ) + [
        "//queng_utils/test_utils:test_utils",
        "//queng_common:common",
    ],
    proc_macro_deps = all_crate_deps(
        proc_macro_dev = True
    ),
    visibility = ["//visibility:public"],
    tags = ["integration", "docker", "docker_test_setup"],
)
