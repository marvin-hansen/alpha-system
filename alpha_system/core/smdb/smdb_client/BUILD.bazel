load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test")

rust_library(
    name = "smdb_client",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    proc_macro_deps = [
        "//thirdparty/crates:async-trait",
        "//thirdparty/crates:enum_dispatch",
    ],
    tags = [
        "provider",
        "smdb_provider",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_config",
        "//alias:proto_smdb",
        # External crates
        "//thirdparty/crates:tonic",
    ],
)

rust_doc(
    name = "doc",
    crate = ":smdb_client",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":smdb_client",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
