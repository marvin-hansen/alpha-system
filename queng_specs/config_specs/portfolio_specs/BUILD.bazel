load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test_suite")

rust_library(
    name = "portfolio_specs",
    srcs = glob([
        "src/*.rs",
    ]),
    tags = [
        "portfolio_specs",
        "specs",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//alias:common",
    ],
)

rust_doc(
    name = "doc",
    crate = ":portfolio_specs",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":portfolio_specs",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
