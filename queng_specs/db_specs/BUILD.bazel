load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test_suite")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test")


rust_library(
    name = "db_specs",
    srcs = glob([
        "src/**/*.rs",
    ]),
    deps =  [
        "//:common",
    ],
    tags = ["specs", "db_specs"],
    visibility = ["//visibility:public"],
)

rust_test_suite(
    name = "tests",
    srcs = glob([
        "tests/*/*_tests.rs",
    ]),
    deps = [
        ":db_specs",
        "//:common",
    ],
    tags = [
        "specs",
        "unit",
    ],
    visibility = ["//visibility:public"],
)


rust_doc(
    name = "doc",
    crate = ":db_specs",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
     name = "doc_test",
     crate = ":db_specs",
     tags = ["doc-test"],
     visibility = ["//visibility:public"],
)
