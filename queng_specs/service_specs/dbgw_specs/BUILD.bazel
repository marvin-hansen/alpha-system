load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test_suite")

rust_library(
    name = "dbgw_specs",
    srcs = glob([
        "src/lib.rs",
    ]),
    tags = [
        "dbgw_specs",
        "service_specs",
        "specs",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal dependencies
        "//alias:common",
    ],
)

rust_doc(
    name = "doc",
    crate = ":dbgw_specs",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":dbgw_specs",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
