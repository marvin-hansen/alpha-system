load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test_suite")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test")

rust_library(
    name = "mddb_specs",
    srcs = glob([
        "src/lib.rs",
    ]),
    deps = [
        # Internal dependencies
        "//queng_common:common",
    ],
    tags = ["specs", "service_specs", "mddb_specs"],
    visibility = ["//visibility:public"],
)

rust_doc(
    name = "doc",
    crate = ":mddb_specs",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
     name = "doc_test",
     crate = ":mddb_specs",
     tags = ["doc-test"],
     visibility = ["//visibility:public"],
)

rust_test_suite(
    name = "mddb_tests",
    srcs = glob([
        "tests/*_tests.rs",
    ]),
    deps =  [
        # Test target
        ":mddb_specs",
        # Internal dependencies
        "//queng_common:common",
    ],
    tags = [
        "specs",
        "unit",
    ],
    visibility = ["//visibility:public"],
)