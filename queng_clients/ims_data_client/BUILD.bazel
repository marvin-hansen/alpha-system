load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library")

rust_library(
    name = "ims_data_client",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    tags = ["client"],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common",
        "//alias:common_config",
        "//alias:rust_proto",
        # Exteral crates
        "@crates//:tokio",
        "@crates//:tonic",
        "@crates//:prost",
    ],
)

rust_doc(
    name = "doc",
    crate = ":ims_data_client",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":ims_data_client",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
