load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library")

rust_library(
    name = "cmdb_client",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    tags = [
        "cmdb_provider",
        "provider",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_exchange",
        "//alias:proto_cmdb",
        "//alias:proto_cmdb_utils",
        # External crates
        "//thirdparty/crates:tokio",
        "//thirdparty/crates:tonic",
        "//thirdparty/crates:prost",
    ],
)

rust_doc(
    name = "doc",
    crate = ":cmdb_client",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":cmdb_client",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
