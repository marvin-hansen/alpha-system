load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library")

rust_library(
    name = "env_utils",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    tags = [
        "env_utils",
        "utils-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_container",
        "//alias:common_env",
        "//alias:config_manager",
        "//alias:container_specs_clickhouse",
        "//alias:container_specs_postgres",
        "//alias:container_specs_kaiko",
        "//alias:clickhouse_utils",
        "//alias:db_specs_postgres",
        "//alias:docker_utils",
        "//alias:kaiko_utils",
        "//alias:portfolio_specs",
        "//alias:postgres_utils",
        "//alias:service_specs_all",
        # External crates
        "//thirdparty/crates:tokio",
        "//thirdparty/crates:serde_json",
    ],
)

rust_doc(
    name = "doc",
    crate = ":env_utils",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    timeout = "short",
    crate = ":env_utils",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)
