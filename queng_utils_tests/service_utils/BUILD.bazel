load("@aspect_bazel_lib//lib:copy_file.bzl", "copy_file")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test", "rust_library", "rust_test")

rust_library(
    name = "service_utils",
    srcs = glob([
        "src/**",
    ]),
    crate_root = "src/lib.rs",
    data = [
        ":copy_core_cmdb",
        ":copy_core_dbgw",
        ":copy_core_smdb",
        #":copy_meta_kaiko_proxy",
        ":copy_meta_mddb",
    ],
    tags = [
        "service_utils",
        "utils-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Internal crates
        "//alias:common_config",
        "//alias:common_env",
        "//alias:config_manager",
        # External crates
        "//thirdparty/crates:tokio",
    ],
)

rust_doc(
    name = "doc",
    crate = ":service_utils",
    tags = ["doc"],
    visibility = ["//visibility:public"],
)

rust_doc_test(
    name = "doc_test",
    crate = ":service_utils",
    tags = ["doc-test"],
    visibility = ["//visibility:public"],
)

## Copy service binary files

# Copy all core services
copy_file(
    name = "copy_core_cmdb",
    src = "//alias/service:cmdb",
    out = "cmdb",
    is_executable = True,
)

copy_file(
    name = "copy_core_dbgw",
    src = "//alias/service:dbgw",
    out = "dbgw",
    is_executable = True,
)

copy_file(
    name = "copy_core_smdb",
    src = "//alias/service:smdb",
    out = "smdb",
    is_executable = True,
)



copy_file(
    name = "copy_meta_mddb",
    src = "//alias/service:mddb",
    out = "mddb",
    is_executable = True,
)
