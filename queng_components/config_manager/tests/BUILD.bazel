load("@rules_rust//rust:defs.bzl", "rust_test_suite")

rust_test_suite(
    name = "cfg_tests",
    srcs = glob([
        "config/*_tests.rs",
    ]),
    tags = [
        "components",
        "config_manager",
        "unit-test",
    ],
    visibility = ["//visibility:public"],
    deps = [
        # Crate to test
        "//alias:config_manager",
        # Internal crates
        "//alias:common_config",
        "//alias:common_env",
        "//alias:exchange_specs",
        "//alias:cmdb_specs",
        "//alias:dbgw_specs",
        "//alias:qdgw_specs",
        "//alias:smdb_specs",
        # External crates
        "//thirdparty/crates:tokio",
    ],
)

