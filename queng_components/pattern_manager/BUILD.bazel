load("@rules_rust//rust:defs.bzl", "rust_library", "rust_test_suite")
load("@rules_rust//rust:defs.bzl", "rust_doc", "rust_doc_test")


rust_library(
    name = "pattern_manager",
    crate_root = "src/lib.rs",
    srcs = glob([
        "src/**",
    ]),
    deps = [
        # Internal crates
        "//queng_common:common",
        # External crates
        "@crate_index//:rust_decimal"
    ],
    visibility = ["//visibility:public"],
)

rust_test_suite(
    name = "tests",
    srcs = glob([
        "tests/pattern_manager_tests.rs",
    ]),
    deps =  [
        "//queng_components/pattern_manager:pattern_manager",
        # Internal crates
        "//queng_common:common",
        # External crates
        "@crate_index//:rust_decimal"
    ],
    tags = ["unit","components", "pattern_manager"],
    visibility = ["//visibility:public"],
)

rust_doc(
    name = "doc",
    crate = ":pattern_manager",
    visibility = ["//visibility:public"],
)

rust_doc_test(
     name = "doc_test",
     crate = ":pattern_manager",
     visibility = ["//visibility:public"],
 )
