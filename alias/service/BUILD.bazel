# The service aliases are used in scripts/run_*.sh to start each service
alias(
    name = "kaiko_proxy",
    actual = "//queng_services/aux/kaiko_proxy:bin",
    visibility = ["//visibility:public"],
)

# The push aliases are used in the root folder BUILD file to build & push containers
alias(
    name = "kaiko_proxy_push",
    actual = "//queng_services/aux/kaiko_proxy:push",
    visibility = ["//visibility:public"],
)

